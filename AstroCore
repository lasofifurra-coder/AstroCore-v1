local function createBarrier()
	local cam = workspace.CurrentCamera
	local root = getRoot()

	local distance = 12
	local pos = root.Position + cam.CFrame.LookVector * distance

	local part = Instance.new("Part")
	part.Size = Vector3.new(10,10,1)
	part.Anchored = true
	part.CanCollide = true
	part.Transparency = 0.4
	part.Material = Enum.Material.ForceField
	part.Color = Color3.fromRGB(170,0,255)
	part.Name = "AstraBarrier"
	part.Parent = workspace

	part.CFrame = CFrame.new(pos, pos + cam.CFrame.LookVector)

	table.insert(barriers, part)
end

