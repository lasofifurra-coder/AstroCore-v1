local function doDash(power)
	if dashCooldown then return end
	dashCooldown = true

	local root = getRoot()
	local cam = workspace.CurrentCamera

	local dir = cam.CFrame.LookVector
	root.AssemblyLinearVelocity = dir * power + Vector3.new(0,10,0)

	-- efecto visual
	local p = Instance.new("Part")
	p.Anchored = true
	p.CanCollide = false
	p.Size = Vector3.new(1,1,1)
	p.Material = Enum.Material.Neon
	p.Color = Color3.fromRGB(255,0,255)
	p.CFrame = root.CFrame
	p.Parent = workspace
	game:GetService("Debris"):AddItem(p,0.3)

	task.wait(0.5)
	dashCooldown = false
end

